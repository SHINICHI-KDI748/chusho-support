# Vercelダッシュボードで設定する環境変数
# https://vercel.com/your-project/settings/environment-variables

# --- Neon PostgreSQL（必須）---
# Neon: https://neon.tech → 新規プロジェクト作成 → Connection stringをコピー
DATABASE_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# --- NextAuth（必須）---
# シークレット: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="本番用の別シークレットを生成して入れる"
# VercelのURLに合わせる（デプロイ後に確定）
NEXTAUTH_URL="https://your-project.vercel.app"

# --- 各アプリのURL（後で各アプリをデプロイしてから更新）---
NEXT_PUBLIC_APP_WORK_URL="https://work.your-domain.com"
NEXT_PUBLIC_APP_INSPECTION_URL="https://inspection.your-domain.com"
NEXT_PUBLIC_APP_DASHBOARD_URL="https://dashboard.your-domain.com"
NEXT_PUBLIC_APP_CASE_URL="https://case.your-domain.com"
